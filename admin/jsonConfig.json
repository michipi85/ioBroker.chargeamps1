{
  "i18n": true,
  "type": "tabs",
  "tabsStyle": {
    "width": "calc(100% - 100px)"
  },
  "items": {
    "tab_1": {
      "type": "panel",
      "label": "Account settings",
      "items": {
        "email": {
          "type": "text",
          "label": "Charge Amps email",
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "password": {
          "type": "password",
          "label": "Charge Amps password",
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 3,
          "xl": 3
        },
        "apiKey": {
          "type": "password",
          "label": "External API key",
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 3,
          "xl": 3
        },

        "Api settings": {
          "type": "header",
          "text": "Api settings",
          "size": 2,
          "newLine": true
        },

        "apiBaseUrl": {
          "type": "text",
          "label": "API base URL",
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 3,
          "xl": 3
        },
        "pollInterval": {
          "type": "number",
          "label": "Poll interval in seconds",
          "min": 30,
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 3,
          "xl": 3
        },

        "RFID settings": {
          "type": "header",
          "text": "RFID settings (for remote start)",
          "size": 2,
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 4,
          "xl": 4
        },

        "rfid": {
          "type": "text",
          "label": "RFID for remote start",
          "newLine": true
        },
        "rfidFormat": {
          "type": "select",
          "label": "RFID format",
          "options": [
            {
              "label": "Hex",
              "value": "Hex"
            },
            {
              "label": "Decimal",
              "value": "Decimal"
            }
          ],
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 4,
          "xl": 4
        },
        "rfidLength": {
          "type": "number",
          "label": "RFID length (HEX: bytes, Decimal: digits)",
          "help": "For HEX values, enter the byte length, e.g. 4 for an 8-character HEX RFID. Leave 0 to calculate automatically.",
          "min": 0,
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 4,
          "xl": 4
        }
      }
    },

    "tab_2": {
      "type": "panel",
      "label": "PV automation",
      "items": {
        "pvAutomationEnabled": {
          "type": "checkbox",
          "label": "Enable PV automation",
          "newLine": true
        },
        "pvChargePointId": {
          "type": "text",
          "label": "Charge point ID",
          "help": "Optional. Leave empty if this adapter has only one connector.",
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 4,
          "xl": 4
        },
        "pvConnectorId": {
          "type": "number",
          "label": "Connector ID",
          "min": 1,
          "xs": 12,
          "sm": 4,
          "md": 4,
          "lg": 2,
          "xl": 2
        },
        "pvGridPowerState": {
          "type": "objectId",
          "label": "Grid power state ID in W",
          "help": "By default negative values mean feed-in/export.",
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "pvGridPowerExportIsNegative": {
          "type": "checkbox",
          "label": "Negative grid power means feed-in"
        },
        "pvBatterySocState": {
          "type": "objectId",
          "label": "Battery SOC state ID",
          "help": "Optional state with house battery state of charge in percent.",
          "newLine": true,
          "xs": 12,
          "sm": 4,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "pvMinBatterySoc": {
          "type": "number",
          "label": "Minimum battery SOC in %",
          "min": 0,
          "max": 100,
          "xs": 12,
          "sm": 2,
          "md": 2,
          "lg": 2,
          "xl": 2
        },
        "pvMinCurrent": {
          "type": "number",
          "label": "Minimum current in A",
          "min": 6,
          "max": 32,
          "newLine": true,
          "xs": 12,
          "sm": 3,
          "md": 3,
          "lg": 3,
          "xl": 3
        },
        "pvMaxCurrent": {
          "type": "number",
          "label": "Maximum current in A",
          "min": 6,
          "max": 32,
          "xs": 12,
          "sm": 3,
          "md": 3,
          "lg": 3,
          "xl": 3
        },
        "pvVoltage": {
          "type": "number",
          "label": "Voltage per phase",
          "min": 1,
          "xs": 12,
          "sm": 3,
          "md": 3,
          "lg": 3,
          "xl": 3
        },
        "pvPhases": {
          "type": "number",
          "label": "Number of phases",
          "min": 1,
          "max": 3,
          "xs": 12,
          "sm": 3,
          "md": 3,
          "lg": 3,
          "xl": 3
        },
        "pvStartSurplusWatts": {
          "type": "number",
          "label": "Start surplus in W",
          "help": "Minimum surplus for charging start.",
          "newLine": true,
          "xs": 12,
          "sm": 4,
          "md": 4,
          "lg": 3,
          "xl": 3
        },
        "pvStopSurplusWatts": {
          "type": "number",
          "label": "Stop surplus in W",
          "help": "Minimum surplus for a charging stop.",
          "xs": 12,
          "sm": 4,
          "md": 4,
          "lg": 3,
          "xl": 3
        },
        "pvStartDelaySeconds": {
          "type": "number",
          "label": "Start delay in seconds",
          "min": 0,
          "newLine": true,
          "xs": 12,
          "sm": 3,
          "md": 3,
          "lg": 3,
          "xl": 3
        },
        "pvStopDelaySeconds": {
          "type": "number",
          "label": "Stop delay in seconds",
          "min": 0,
          "xs": 12,
          "sm": 3,
          "md": 3,
          "lg": 3,
          "xl": 3
        },
        "pvCompletionStandbyDelaySeconds": {
          "type": "number",
          "label": "Standby delay after charging in seconds",
          "help": "Time until the wallbox enters standby mode when charging is complete.",
          "min": 0,
          "xs": 12,
          "sm": 3,
          "md": 3,
          "lg": 3,
          "xl": 3
        },
        "pvSunsetState": {
          "type": "objectId",
          "label": "Sunset state ID",
          "help": "If, after the pause, no surplus is generated until sunset, the wallbox is put into standby mode.",
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 4,
          "xl": 4
        }
      }
    },

    "tab_3": {
      "type": "panel",
      "label": "Schedule automation",
      "items": {
        "scheduleAutomationEnabled": {
          "type": "checkbox",
          "label": "Enable schedule automation",
          "help": "Creates schedule states and allows the adapter to start charging at the configured time.",
          "newLine": true
        },
        "scheduleChargePointId": {
          "type": "text",
          "label": "Charge point ID",
          "help": "Optional. Leave empty if this adapter has only one connector.",
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 4,
          "xl": 4
        },
        "scheduleConnectorId": {
          "type": "number",
          "label": "Connector ID",
          "min": 1,
          "xs": 12,
          "sm": 4,
          "md": 4,
          "lg": 2,
          "xl": 2
        },
        "scheduleTime": {
          "type": "text",
          "label": "Schedule time",
          "help": "Time in HH:mm format, for example 22:30.",
          "newLine": true,
          "xs": 12,
          "sm": 4,
          "md": 4,
          "lg": 3,
          "xl": 3
        },
        "scheduleCurrent": {
          "type": "number",
          "label": "Schedule current in A",
          "min": 6,
          "max": 32,
          "xs": 12,
          "sm": 4,
          "md": 4,
          "lg": 3,
          "xl": 3
        },
        "scheduleMonday": {
          "type": "checkbox",
          "label": "Monday",
          "newLine": true,
          "xs": 6,
          "sm": 3,
          "md": 2,
          "lg": 1,
          "xl": 1
        },
        "scheduleTuesday": {
          "type": "checkbox",
          "label": "Tuesday",
          "xs": 6,
          "sm": 3,
          "md": 2,
          "lg": 1,
          "xl": 1
        },
        "scheduleWednesday": {
          "type": "checkbox",
          "label": "Wednesday",
          "xs": 6,
          "sm": 3,
          "md": 2,
          "lg": 1,
          "xl": 1
        },
        "scheduleThursday": {
          "type": "checkbox",
          "label": "Thursday",
          "xs": 6,
          "sm": 3,
          "md": 2,
          "lg": 1,
          "xl": 1
        },
        "scheduleFriday": {
          "type": "checkbox",
          "label": "Friday",
          "xs": 6,
          "sm": 3,
          "md": 2,
          "lg": 1,
          "xl": 1
        },
        "scheduleSaturday": {
          "type": "checkbox",
          "label": "Saturday",
          "xs": 6,
          "sm": 3,
          "md": 2,
          "lg": 1,
          "xl": 1
        },
        "scheduleSunday": {
          "type": "checkbox",
          "label": "Sunday",
          "xs": 6,
          "sm": 3,
          "md": 2,
          "lg": 1,
          "xl": 1
        }
      }
    }
  }
}
