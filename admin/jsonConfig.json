{
  "type": "panel",
  "items": {
    "email": {
      "type": "text",
      "label": "Charge Amps email",
      "newLine": true
    },
    "password": {
      "type": "password",
      "label": "Charge Amps password",
      "newLine": true
    },
    "apiKey": {
      "type": "password",
      "label": "External API key",
      "newLine": true
    },
    "apiBaseUrl": {
      "type": "text",
      "label": "API base URL",
      "newLine": true
    },
    "pollInterval": {
      "type": "number",
      "label": "Poll interval in seconds",
      "min": 30,
      "newLine": true
    },
    "rfid": {
      "type": "text",
      "label": "RFID for remote start",
      "newLine": true
    },
    "rfidFormat": {
      "type": "select",
      "label": "RFID format",
      "options": [
        {
          "label": "Hex",
          "value": "Hex"
        },
        {
          "label": "Decimal",
          "value": "Decimal"
        }
      ],
      "newLine": true
    },
    "rfidLength": {
      "type": "number",
      "label": "RFID length",
      "min": 0,
      "newLine": true
    }
  }
}